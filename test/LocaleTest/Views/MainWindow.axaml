<w:AppWindow
  x:Class="LocaleTest.Views.MainWindow"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="clr-namespace:AvaloniaFluentUI.Controls;assembly=AvaloniaFluentUI"
  xmlns:vm="using:LocaleTest.ViewModels"
  xmlns:w="clr-namespace:AvaloniaFluentUI.Windowing;assembly=AvaloniaFluentUI"
  d:DesignHeight="450"
  d:DesignWidth="800"
  x:DataType="vm:MainWindowViewModel"
  Icon="/Assets/avalonia-logo.ico"
  mc:Ignorable="d">

  <Design.DataContext>
    <!--
      This only sets the DataContext for the previewer in an IDE,
      to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs)
    -->
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Window.Styles>
    <Style Selector="ui|SegmentedToggleView /template/ Border#PART_HeaderBorder">
      <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
  </Window.Styles>

  <w:AppWindow.TitleBarContent>
    <ui:ToolButton
      Width="46"
      Height="40"
      HorizontalAlignment="Right"
      VerticalAlignment="Stretch"
      Command="{Binding ToggleThemeCommand}"
      IconData="M15 3v-2q0-0.406 0.297-0.703t0.703-0.297 0.703 0.297 0.297 0.703v2q0 0.406-0.297 0.703t-0.703 0.297-0.703-0.297-0.297-0.703zM8 7q0 0.406-0.297 0.703t-0.703 0.297-0.703-0.297l-2-2q-0.297-0.297-0.297-0.703t0.297-0.703 0.703-0.297 0.703 0.297l2 2q0.297 0.297 0.297 0.703zM27 4q0.406 0 0.703 0.297t0.297 0.703-0.297 0.703l-2 2q-0.297 0.297-0.703 0.297t-0.703-0.297-0.297-0.703 0.297-0.703l2-2q0.297-0.297 0.703-0.297zM24 16v0.156q0 1.625-0.648 3.055t-1.75 2.492-2.547 1.68-3.055 0.617q-1.656 0-3.117-0.625t-2.547-1.711-1.711-2.547-0.625-3.117 0.625-3.117 1.711-2.547 2.547-1.711 3.117-0.625 3.117 0.625 2.547 1.711 1.711 2.547 0.625 3.117zM16 22h0.125q1.219 0 2.289-0.484t1.867-1.313 1.258-1.914 0.461-2.289-0.461-2.289-1.258-1.914-1.867-1.313-2.289-0.484h-0.125v12zM3 15q0.406 0 0.703 0.297t0.297 0.703-0.297 0.703-0.703 0.297h-2q-0.406 0-0.703-0.297t-0.297-0.703 0.297-0.703 0.703-0.297h2zM31 15q0.406 0 0.703 0.297t0.297 0.703-0.297 0.703-0.703 0.297h-2q-0.406 0-0.703-0.297t-0.297-0.703 0.297-0.703 0.703-0.297h2zM7 24q0.406 0 0.703 0.297t0.297 0.703-0.297 0.703l-2 2q-0.297 0.297-0.703 0.297t-0.703-0.297-0.297-0.703 0.297-0.703l2-2q0.297-0.297 0.703-0.297zM28 27q0 0.406-0.297 0.703t-0.703 0.297-0.703-0.297l-2-2q-0.297-0.297-0.297-0.703t0.297-0.703 0.703-0.297 0.703 0.297l2 2q0.297 0.297 0.297 0.703zM17 29v2q0 0.406-0.297 0.703t-0.703 0.297-0.703-0.297-0.297-0.703v-2q0-0.406 0.297-0.703t0.703-0.297 0.703 0.297 0.297 0.703z"
      Theme="{StaticResource TransparentToolButton}"/>
  </w:AppWindow.TitleBarContent>

  <Grid
    Margin="0,50,0,0"
    HorizontalAlignment="Stretch"
    RowDefinitions="Auto, Auto, Auto, *"
    RowSpacing="12">

    <ui:SearchTextBox
      Grid.Row="0"
      Width="256"
      HorizontalAlignment="Center"
      OnSearchTriggered="OnSearch"/>

    <StackPanel
      Grid.Row="1"
      HorizontalAlignment="Center"
      Orientation="Horizontal"
      Spacing="5">
      <ui:PushButton
        HorizontalAlignment="Center"
        Classes="Outlined"
        Command="{Binding ToggleLanguageCommand}"
        CommandParameter="en-US"
        Content="切换语言到en-US"/>
      <ui:PushButton
        HorizontalAlignment="Center"
        Classes="Outlined"
        Command="{Binding ToggleLanguageCommand}"
        CommandParameter="zh-CN"
        Content="切换语言到zh-CN"/>
      <ui:PushButton
        HorizontalAlignment="Center"
        Classes="Outlined"
        Command="{Binding ToggleLanguageCommand}"
        CommandParameter="ja-JP"
        Content="切换语言到ja-JP"/>
      <ui:PushButton
        HorizontalAlignment="Center"
        Classes="Outlined"
        Command="{Binding ToggleLanguageCommand}"
        CommandParameter="en-US"
        Content="切换默认语言"/>
    </StackPanel>
    <ui:SegmentedToggleView
      Grid.Row="2"
      HorizontalAlignment="Center"
      SelectedItem="{Binding SelectedItem}">
      <ui:SegmentedItem Content="{Binding Home}" IsSelected="True"/>
      <ui:SegmentedItem Content="{Binding Icon}"/>
      <ui:SegmentedItem Content="{Binding BasicInput}"/>
      <ui:SegmentedItem Content="{Binding View}"/>
      <ui:SegmentedItem Content="{Binding Layout}"/>
      <ui:SegmentedItem Content="{Binding Scroll}"/>
      <ui:SegmentedItem Content="{Binding Navigation}"/>
      <ui:SegmentedItem Content="{Binding Setting}"/>
    </ui:SegmentedToggleView>

    <TextBlock
      Grid.Row="3"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      FontSize="24"
      Text="{Binding SelectedItemFormat}"
      TextAlignment="Center"/>
  </Grid>

</w:AppWindow>
