<ui:ViewBase
  x:Class="Gallery.Pages.SegmentedViewPage"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:fi="clr-namespace:AvaloniaFluentUI.Icons;assembly=AvaloniaFluentUI"
  xmlns:fui="clr-namespace:AvaloniaFluentUI.Controls;assembly=AvaloniaFluentUI"
  xmlns:locale="clr-namespace:AvaloniaFluentUI.Locale;assembly=AvaloniaFluentUI"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="clr-namespace:Gallery.Controls"
  xmlns:viewModel="clr-namespace:Gallery.ViewModels"
  Title="{Binding Title}"
  d:DesignWidth="800"
  x:DataType="viewModel:SegmentedViewPageViewModel"
  mc:Ignorable="d">

  <ui:ViewBase.Styles>
    <Style Selector="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
  </ui:ViewBase.Styles>

  <StackPanel Spacing="50">
    <ui:CodeCard
      Name="SegmentedCard"
      Title="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_SegmentedBar]}"
      Height="400">
      <Grid RowDefinitions="Auto, *">

        <fui:SegmentedView SelectedIndex="0" SelectedItem="{Binding SegmentedSelectedItem}">
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_Home]}" IsSelected="True"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_Files]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Edit]}"/>
          <fui:SegmentedItem>
            <Grid ColumnDefinitions="*, *" ColumnSpacing="5">
              <PathIcon Data="{x:Static fi:FluentIcon.View}"/>
              <TextBlock Grid.Column="1" Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[View]}"/>
            </Grid>
          </fui:SegmentedItem>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[BasicInput]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[DialogAndPopup]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Run2]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_Window]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_VideoHistory]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_AudioHistory]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_BrowsingHistory]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_Help]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[Settings]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_About]}"/>
          <fui:SegmentedItem>
            <Grid ColumnDefinitions="*, *" ColumnSpacing="5">
              <PathIcon Data="{x:Static fi:FluentIcon.Send}"/>
              <TextBlock Grid.Column="1" Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[BI_Send]}"/>
            </Grid>
          </fui:SegmentedItem>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_Files]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_Folders]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_Apps]}"/>
        </fui:SegmentedView>
        <TextBlock
          Grid.Row="1"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          FontSize="24"
          Text="{Binding SelectedItemFormat}"
          TextAlignment="Center"/>
      </Grid>
    </ui:CodeCard>


    <ui:CodeCard Title="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_SegmentedToggleBar]}" Height="400">
      <Grid RowDefinitions="Auto, *">
        <fui:SegmentedToggleView SelectedIndex="0" SelectedItem="{Binding SegmentedToggleSelectedItem}">
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_Home]}" IsSelected="True"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_Files]}"/>
          <fui:SegmentedItem>
            <PathIcon Data="{x:Static fi:FluentIcon.Edit}"/>
          </fui:SegmentedItem>
          <fui:SegmentedItem>
            <Grid ColumnDefinitions="*, *" ColumnSpacing="5">
              <PathIcon Data="{StaticResource View}"/>
              <TextBlock Grid.Column="1" Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[View]}"/>
            </Grid>
          </fui:SegmentedItem>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[BasicInput]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[DialogAndPopup]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Run2]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_Window]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_VideoHistory]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_AudioHistory]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_BrowsingHistory]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_Help]}"/>
          <fui:SegmentedItem>
            <PathIcon Data="{x:Static fi:FluentIcon.Setting}"/>
          </fui:SegmentedItem>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_About]}"/>
          <fui:SegmentedItem>
            <Grid ColumnDefinitions="*, *" ColumnSpacing="5">
              <PathIcon Data="{x:Static fi:FluentIcon.Send}"/>
              <TextBlock Grid.Column="1" Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[BI_Send]}"/>
            </Grid>
          </fui:SegmentedItem>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_Files]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_Folders]}"/>
          <fui:SegmentedItem Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_Apps]}"/>
        </fui:SegmentedToggleView>
        <TextBlock
          Grid.Row="1"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          FontSize="24"
          Text="{Binding SegmentedSelectedItemFormat}"
          TextAlignment="Center"/>
      </Grid>
    </ui:CodeCard>
  </StackPanel>
</ui:ViewBase>
