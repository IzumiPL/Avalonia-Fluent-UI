          <fui:CommandBarButton IconSource="Delete" Label="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Delete]}"/>
          <fui:CommandBarButton IconSource="Share" Label="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Share]}"/>
          <fui:CommandBarElementContainer>
            <DropDownButton Theme="{StaticResource TransparentDropDownButton}">
              <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
                <PathIcon Data="{x:Static fi:FluentIcon.Scroll}"/>
                <TextBlock Grid.Column="1" Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Sort]}"/>
              </Grid>
              <DropDownButton.Flyout>
                <fui:FluentMenuFlyout>
                  <MenuItem
                    GroupName="Top"
                    Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_CreationDate]}"
                    IsSelected="True"
                    ToggleType="Radio"/>
                  <MenuItem
                    GroupName="Top"
                    Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_TakeDate]}"
                    ToggleType="Radio"/>
                  <MenuItem
                    GroupName="Top"
                    Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_ModificationDate]}"
                    ToggleType="Radio"/>
                  <MenuItem
                    GroupName="Top"
                    Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Name]}"
                    ToggleType="Radio"/>

                  <Separator HorizontalAlignment="Stretch"/>

                  <MenuItem
                    GroupName="Bottom"
                    Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Ascending]}"
                    ToggleType="Radio"/>
                  <MenuItem
                    GroupName="Bottom"
                    Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Descending]}"
                    IsChecked="True"
                    ToggleType="Radio"/>
                </fui:FluentMenuFlyout>
              </DropDownButton.Flyout>
            </DropDownButton>
          </fui:CommandBarElementContainer>
        </fui:CommandBar.PrimaryCommands>

        <fui:CommandBar.SecondaryCommands>
          <fui:CommandBarButton IconSource="Setting" Label="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[Settings]}"/>
        </fui:CommandBar.SecondaryCommands>
      </fui:CommandBar>
    </ui:CodeCard>

    <ui:CodeCard Name="CommandBarFlyoutCard" Title="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_CommandBarFlyout]}">
      <Image
        Name="Image"
        Width="512"
        HorizontalAlignment="Left"
        Stretch="Uniform"/>
    </ui:CodeCard>
  </StackPanel>
</ui:ViewBase>
