              </MenuItem.Icon>
            </MenuItem>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_NewProjectSettings]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_ManageIDESettings]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_PowerSaveMode]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_InvalidateCache]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Exit]}"/>
          </MenuItem>

          <!--  Edit  -->
          <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_EditMenu]}">
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[BI_Undo]}"
              HotKey="Ctrl+Z"
              InputGesture="Ctrl+Z"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Redo]}"
              HotKey="Ctrl+Shift+Z"
              InputGesture="Ctrl+Shift+Z"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[BI_Cut]}"
              HotKey="Ctrl+X"
              InputGesture="Ctrl+X"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="复制"
              HotKey="Ctrl+C"
              InputGesture="Ctrl+C"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_CopyPlainText]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[BI_Paste]}"
              HotKey="Ctrl+V"
              InputGesture="Ctrl+V"/>
            <Separator/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="删除"
              HotKey="Delete"
              InputGesture="Delete"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_SearchSelection]}"
              HotKey="Ctrl+Alt+E"
              InputGesture="Ctrl+Alt+E"/>
            <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Find]}">
              <MenuItem
                Command="{Binding ClickedMenuItemCommand}"
                CommandParameter="{Binding $self.Header}"
                Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Find]}"/>
              <MenuItem
                Command="{Binding ClickedMenuItemCommand}"
                CommandParameter="{Binding $self.Header}"
                Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Replace]}"/>
              <MenuItem
                Command="{Binding ClickedMenuItemCommand}"
                CommandParameter="{Binding $self.Header}"
                Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_FindNext]}"/>
              <MenuItem
                Command="{Binding ClickedMenuItemCommand}"
                CommandParameter="{Binding $self.Header}"
                Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_FindPrevious]}"/>
              <Separator/>

              <MenuItem
                Command="{Binding ClickedMenuItemCommand}"
                CommandParameter="{Binding $self.Header}"
                Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_SelectAllMatches]}"/>
              <MenuItem
                Command="{Binding ClickedMenuItemCommand}"
                CommandParameter="{Binding $self.Header}"
                Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_AddNextMatch]}"/>
              <MenuItem
                Command="{Binding ClickedMenuItemCommand}"
                CommandParameter="{Binding $self.Header}"
                Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_CancelSelectedMatch]}"/>
            </MenuItem>
            <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_FindUsages]}">
              <MenuItem
                Command="{Binding ClickedMenuItemCommand}"
                CommandParameter="{Binding $self.Header}"
                Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_NextHighlightedUsage]}"
                IsEnabled="False"/>
              <MenuItem
                Command="{Binding ClickedMenuItemCommand}"
                CommandParameter="{Binding $self.Header}"
                Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_PreviousHighlightedUsage]}"
                IsEnabled="False"/>
              <MenuItem
                Command="{Binding ClickedMenuItemCommand}"
                CommandParameter="{Binding $self.Header}"
                Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_RecentFindUsages]}"/>
            </MenuItem>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_SelectAll]}"
              HotKey="Ctrl+A"
              InputGesture="Ctrl+A"/>
          </MenuItem>

          <!--  View  -->
          <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_ViewMenu]}">
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_ToolWindow]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Appearance]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_QuickDefinition]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_QuickDefinitionType]}"/>
            <Separator/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_RecentLocations]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_RecentFiles]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_RecentlyChangedFiles]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_RecentChanges]}"/>
          </MenuItem>

          <!--  Navigation  -->
          <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_NavigationMenu]}">
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Back]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Forward]}"
              IsEnabled="False"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_SearchEverywhere]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Class]}"
              HotKey="Ctrl+N"
              InputGesture="Ctrl+N"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_File]}"
              HotKey="Ctrl+Shift+N"
              InputGesture="Ctrl+Shift+N"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Symbol]}"
              HotKey="Ctrl+Alt+Shift+N"
              InputGesture="Ctrl+Alt+Shift+N"/>
          </MenuItem>

          <!--  Code  -->
          <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_CodeMenu]}">
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_CodeCompletion]}"
              IsEnabled="False"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_InspectCode]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_AnalyzeCode]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_InsertLiveTemplate]}"
              HotKey="Ctrl+J"
              InputGesture="Ctrl+J"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_SaveAsLiveTemplate]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_SurroundWithTemplate]}"
              HotKey="Ctrl+Alt+T"
              InputGesture="Ctrl+Alt+T"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_UnwrapRemove]}"
              HotKey="Ctrl+Shift+Delete"
              InputGesture="Ctrl+Shift+Delete"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Collapse]}"/>
          </MenuItem>

          <!--  Refactoring  -->
          <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_RefactorMenu]}">
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Rename]}"
              HotKey="Shift+F6"
              InputGesture="Shift+F6"/>
          </MenuItem>

          <!--  Build  -->
          <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_BuildMenu]}">
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_BuildSolution]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_RebuildSolution]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_CleanSolution]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_BuildCurrentProject]}"
              IsEnabled="False"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_BuildStartupProject]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_AdvancedBuild]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_ChangeSolutionConfig]}"/>
          </MenuItem>

          <!--  Run  -->
          <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_RunMenu]}">
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_RerunProject]}"
              HotKey="Shift+F10"
              InputGesture="Shift+F10"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_DebugGallery]}"
              HotKey="Shift+F9"
              InputGesture="Shift+F9"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_RunWithProfiler]}"
              IsEnabled="False"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_AnalyzeGallery]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Run2]}"
              HotKey="Alt+Shift+F10"
              InputGesture="Alt+Shift+F10"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Debug]}"
              HotKey="Alt+Shift+F9"
              InputGesture="Alt+Shift+F9"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_AttachToProcess]}"
              HotKey="Ctrl+Alt+F5"
              InputGesture="Ctrl+Alt+F5"/>
          </MenuItem>
        </Menu>
      </DockPanel>
      <ui:CodeCard.CodeContent>
        <TextBlock
          Margin="10"
          HorizontalAlignment="Left"
          VerticalAlignment="Center">
          <Run Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_CommandText]}"/>
          <Run Foreground="OrangeRed" Text="{Binding CommandText}"/>
        </TextBlock>
      </ui:CodeCard.CodeContent>
    </ui:CodeCard>

    <ui:CodeCard Name="MenuCard" Title="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_ContextMenu]}">
      <Border
        Height="256"
        Margin="24"
        Background="Moccasin"
        CornerRadius="10">
        <Border.ContextMenu>
          <fui:FluentContextMenu Width="300">
            <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto">
              <Image
                Grid.RowSpan="3"
                Grid.Column="0"
                Width="64"
                Height="64"
                Margin="-18,0,10,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                RenderOptions.BitmapInterpolationMode="HighQuality"
                Source="avares://Gallery/Assets/Images/avater.png"
                Stretch="Uniform"/>
              <TextBlock
                Grid.Row="0"
                Grid.Column="1"
                Margin="11,0,0,0"
                VerticalAlignment="Center"
                FontSize="18"
                Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_LoginName]}"/>
              <TextBlock
                Grid.Row="1"
                Grid.Column="1"
                Margin="11,0,0,0"
                VerticalAlignment="Center"
                FontSize="12"
                Text="hanserinterval@outlook.com"/>
              <Button
                Grid.Row="2"
                Grid.Column="1"
                HorizontalAlignment="Left"
                Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Logout]}"
                Foreground="{DynamicResource SystemAccentColor}"
                Theme="{StaticResource TransparentButton}"/>
            </Grid>
            <Separator HorizontalAlignment="Stretch"/>
            <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_ManageAccounts]}">
              <MenuItem.Icon>
                <PathIcon Data="{x:Static fi:FluentIcon.People}"/>
              </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_PaymentMethods]}">
              <MenuItem.Icon>
                <PathIcon Data="{x:Static fi:FluentIcon.ShoppingCart}"/>
              </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_RedeemCode]}">
              <MenuItem.Icon>
                <PathIcon Data="{x:Static fi:FluentIcon.Code}"/>
              </MenuItem.Icon>
            </MenuItem>
            <Separator HorizontalAlignment="Stretch"/>
            <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[Settings]}">
              <MenuItem.Icon>
                <PathIcon Data="{x:Static fi:FluentIcon.Setting}"/>
              </MenuItem.Icon>
            </MenuItem>
          </fui:FluentContextMenu>
        </Border.ContextMenu>
        <TextBlock
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          FontSize="24"
          Text="Right Clicked Here"/>
      </Border>
    </ui:CodeCard>


    <ui:CodeCard Title="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Sort]}">
      <Border
        Height="256"
        Margin="24"
        Background="CornflowerBlue"
        CornerRadius="10">
        <Border.ContextMenu>
          <fui:FluentContextMenu>
            <MenuItem
              GroupName="Top"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_CreationDate]}"
              IsChecked="True"
              ToggleType="CheckBox"/>
            <MenuItem
              GroupName="Top"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_TakeDate]}"
              ToggleType="CheckBox"/>
            <MenuItem
              GroupName="Top"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_ModificationDate]}"
              ToggleType="CheckBox"/>
            <MenuItem
              GroupName="Top"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Name]}"
              ToggleType="CheckBox"/>

            <Separator HorizontalAlignment="Stretch"/>

            <MenuItem
              GroupName="Bottom"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Ascending]}"
              ToggleType="Radio"/>
            <MenuItem
              GroupName="Bottom"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Descending]}"
              IsChecked="True"
              ToggleType="Radio"/>
          </fui:FluentContextMenu>
        </Border.ContextMenu>
        <TextBlock
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          FontSize="24"
          Text="Right Clicked Here"/>
      </Border>
    </ui:CodeCard>

    <!--  ContextMenu  -->
    <ui:CodeCard Title="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_ContextMenu]}">
      <Border
        MinHeight="256"
        Margin="24"
        Background="#F497FF"
        CornerRadius="10">
        <Border.ContextMenu>
          <fui:FluentContextMenu Name="ContextMenu">
            <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[Copy]}" InputGesture="Ctrl+C">
              <MenuItem.Icon>
                <PathIcon Data="{x:Static fi:FluentIcon.Copy}"/>
              </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[Cut]}" InputGesture="Ctrl+X">
              <MenuItem.Icon>
                <PathIcon Data="{x:Static fi:FluentIcon.Cut}"/>
              </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[Paste]}" InputGesture="Ctrl+V">
              <MenuItem.Icon>
                <PathIcon Data="{x:Static fi:FluentIcon.Paste}"/>
              </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[SelectAll]}" InputGesture="Ctrl+A"/>
          </fui:FluentContextMenu>
        </Border.ContextMenu>
        <TextBlock
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          FontSize="24"
          Text="Right Clicked Here"/>
      </Border>
    </ui:CodeCard>

