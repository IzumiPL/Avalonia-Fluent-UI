<ui:ViewBase
  x:Class="Gallery.Views.MenuAndToolBarView"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:fi="clr-namespace:AvaloniaFluentUI.Icons;assembly=AvaloniaFluentUI"
  xmlns:fui="clr-namespace:AvaloniaFluentUI.Controls;assembly=AvaloniaFluentUI"
  xmlns:locale="clr-namespace:AvaloniaFluentUI.Locale;assembly=AvaloniaFluentUI"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="clr-namespace:Gallery.Controls"
  xmlns:viewModel="clr-namespace:Gallery.ViewModels"
  Title="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MenuAndToolBar]}"
  d:DesignHeight="450"
  d:DesignWidth="800"
  x:DataType="viewModel:MenuAndToolBarViewModel"
  mc:Ignorable="d">

  <ui:ViewBase.Styles>
    <Style Selector="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBox">
      <Setter Property="MinWidth" Value="128"/>
    </Style>

    <Style Selector="TextBlock.Title">
      <Setter Property="FontSize" Value="28"/>
      <Setter Property="Margin" Value="0 5 0 15"/>
      <Setter Property="FontWeight" Value="ExtraBold"/>
    </Style>

    <Style Selector="ui|CodeCard /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Padding" Value="15"/>
    </Style>

    <!-- <Style Selector="MenuItem"> -->
    <!-- <Setter Property="Foreground" Value="{DynamicResource TextControlForeground}"/> -->
    <!-- </Style> -->

    <!-- <Style Selector="MenuItem:pointerover"> -->
    <!-- <Setter Property="Foreground" Value="#FFFFFF"/> -->
    <!-- </Style> -->
  </ui:ViewBase.Styles>

  <ui:ViewBase.Resources>
    <fui:CommandBarFlyout
      x:Key="CommandBarFlyout"
      Placement="Right"
      ShowMode="Transient">
      <fui:CommandBarFlyout.PrimaryCommands>
        <fui:CommandBarButton IconSource="Copy" Label="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[BI_Copy]}"/>
        <fui:CommandBarButton IconSource="Save" Label="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[BI_Save]}"/>
        <fui:CommandBarButton IconSource="Delete" Label="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Delete]}"/>
        <fui:CommandBarButton IconSource="Share" Label="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Share]}"/>
      </fui:CommandBarFlyout.PrimaryCommands>
      <fui:CommandBarFlyout.SecondaryCommands>
        <fui:CommandBarButton
          HotKey="Ctrl+S"
          IconSource="Setting"
          Label="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[Settings]}"/>
        <fui:CommandBarButton
          HotKey="Ctrl+Z"
          IconSource="Redo"
          Label="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[BI_Undo]}"/>
      </fui:CommandBarFlyout.SecondaryCommands>
    </fui:CommandBarFlyout>
  </ui:ViewBase.Resources>

  <StackPanel Spacing="50">

    <!--  Menu  -->
    <ui:CodeCard Name="MenuBarCard" Title="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Menu]}">
      <DockPanel>
        <Menu DockPanel.Dock="Top">
          <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_FileMenu]}">
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_NewSolution]}"
              HotKey="Ctrl+Alt+Shift+C"
              InputGesture="Ctrl+Alt+Shift+C"/>
            <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Open]}">
              <MenuItem
                Command="{Binding ClickedMenuItemCommand}"
                CommandParameter="{Binding $self.Header}"
                Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Open]}"
                HotKey="Ctrl+Shift+O"
                InputGesture="Ctrl+Shift+O">
                <MenuItem.Icon>
                  <PathIcon Data="M16.297 8l-1.055 0.734-1.047 0.641-1.133 0.453-1.281 0.172h-9.781v15l0.234 1.156 0.648 0.961 0.961 0.648 1.156 0.234h22l1.156-0.234 0.961-0.648 0.648-0.961 0.234-1.156v-14l-0.234-1.156-0.648-0.961-0.961-0.648-1.156-0.234h-10.703zM5 4l-1.156 0.234-0.961 0.648-0.648 0.961-0.234 1.156v1h9.781l0.781-0.109 0.703-0.289 0.656-0.398 0.641-0.453-0.703-0.977-0.75-0.883-0.914-0.641-1.195-0.25h-6zM4.891 2h6.109l1.002 0.084 0.85 0.252 1.398 0.898 1.156 1.281 1.094 1.484h10.609l0.961 0.1 0.914 0.299 0.834 0.465 0.721 0.598 0.598 0.721 0.465 0.834 0.299 0.914 0.1 0.961v14.219l-0.1 0.961-0.299 0.914-0.465 0.834-0.598 0.721-0.721 0.598-0.834 0.465-0.914 0.299-0.961 0.1h-22.219l-0.961-0.1-0.914-0.299-0.834-0.465-0.721-0.598-0.598-0.721-0.465-0.834-0.299-0.914-0.1-0.961v-18.219l0.1-0.961 0.299-0.914 0.465-0.834 0.598-0.721 0.721-0.598 0.834-0.465 0.914-0.299 0.961-0.1z"/>
                </MenuItem.Icon>
              </MenuItem>
              <MenuItem
                Command="{Binding ClickedMenuItemCommand}"
                CommandParameter="{Binding $self.Header}"
                Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_GetFromVersionControl]}"/>
            </MenuItem>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_CloseSolution]}"
              HotKey="Ctrl+Alt+Shift+Q"
              InputGesture="Ctrl+Alt+Shift+Q"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_RemoteDevelopment]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_SaveAll]}"
              HotKey="Ctrl+S"
              InputGesture="Ctrl+S"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_ReloadAllFromDisk]}"
              HotKey="Ctrl+Alt+Y"
              InputGesture="Ctrl+Alt+Y"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Export]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Print]}"/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_FileEncoding]}"/>
            <MenuItem Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_LineEndings]}">
              <MenuItem
                Command="{Binding ClickedMenuItemCommand}"
                CommandParameter="{Binding $self.Header}"
                Header="CRLF - Windows(\r\n)"/>
              <MenuItem
                Command="{Binding ClickedMenuItemCommand}"
                CommandParameter="{Binding $self.Header}"
                Header="LF - Unix 和 macOS(\n)"/>
              <MenuItem
                Command="{Binding ClickedMenuItemCommand}"
                CommandParameter="{Binding $self.Header}"
                Header="CR - Classic Mac OS(\r)"/>
            </MenuItem>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_SetReadOnly]}"/>
            <Separator/>
            <MenuItem
              Command="{Binding ClickedMenuItemCommand}"
              CommandParameter="{Binding $self.Header}"
              Header="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[Settings]}"
              HotKey="Ctrl+Alt+S"
              InputGesture="Ctrl+Alt+S">
              <MenuItem.Icon>
                <PathIcon Data="M16 12l-0.408 0.020-0.395 0.059-0.382 0.098-0.37 0.137-0.352 0.171-0.33 0.2-0.307 0.229-0.285 0.259-0.259 0.285-0.229 0.307-0.2 0.33-0.171 0.352-0.137 0.37-0.098 0.382-0.059 0.395-0.020 0.408 0.020 0.408 0.059 0.395 0.098 0.382 0.137 0.37 0.171 0.352 0.2 0.33 0.229 0.307 0.259 0.285 0.285 0.259 0.307 0.23 0.33 0.2 0.352 0.171 0.37 0.137 0.382 0.098 0.395 0.059 0.408 0.020 0.408-0.020 0.395-0.059 0.382-0.098 0.37-0.137 0.352-0.171 0.33-0.2 0.307-0.23 0.285-0.259 0.259-0.285 0.23-0.307 0.2-0.33 0.171-0.352 0.137-0.37 0.098-0.382 0.059-0.395 0.020-0.408-0.020-0.408-0.059-0.395-0.098-0.382-0.137-0.37-0.171-0.352-0.2-0.33-0.23-0.307-0.259-0.285-0.285-0.259-0.307-0.229-0.33-0.2-0.352-0.171-0.37-0.137-0.382-0.098-0.395-0.059-0.408-0.020zM16 10l0.615 0.029 0.596 0.088 0.576 0.146 0.557 0.205 0.529 0.256 0.494 0.299 0.459 0.342 0.424 0.385 0.385 0.424 0.342 0.459 0.299 0.494 0.256 0.529 0.205 0.557 0.146 0.576 0.088 0.596 0.029 0.615-0.029 0.615-0.088 0.596-0.146 0.576-0.205 0.557-0.256 0.529-0.299 0.494-0.342 0.459-0.385 0.424-0.424 0.385-0.459 0.342-0.494 0.299-0.529 0.256-0.557 0.205-0.576 0.146-0.596 0.088-0.615 0.029-0.615-0.029-0.596-0.088-0.576-0.146-0.557-0.205-0.529-0.256-0.494-0.299-0.459-0.342-0.424-0.385-0.385-0.424-0.342-0.459-0.299-0.494-0.256-0.529-0.205-0.557-0.146-0.576-0.088-0.596-0.029-0.615 0.029-0.615 0.088-0.596 0.146-0.576 0.205-0.557 0.256-0.529 0.299-0.494 0.342-0.459 0.385-0.424 0.424-0.385 0.459-0.342 0.494-0.299 0.529-0.256 0.557-0.205 0.576-0.146 0.596-0.088 0.615-0.029zM16 2l-1.125 0.039-1.109 0.117-0.266 1.547-0.297 1.531-0.083 0.337-0.108 0.325-0.134 0.312-0.159 0.299-0.383 0.545-0.461 0.463-0.531 0.377-0.594 0.287-0.318 0.106-0.33 0.076-0.342 0.045-0.354 0.015-0.347-0.015-0.337-0.044-0.327-0.073-0.317-0.103h-0.016l-2.875-1.063h-0.016l-0.684 0.908-0.613 0.943-0.535 0.986-0.449 1.037v0.016l2.391 2.031 0.31 0.288 0.272 0.316 0.235 0.344 0.198 0.373 0.157 0.392 0.112 0.403 0.067 0.414 0.022 0.424-0.023 0.425-0.069 