<ui:ViewBase
  x:Class="Gallery.Views.BasicInputView"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:fui="clr-namespace:AvaloniaFluentUI.UI.Controls;assembly=AvaloniaFluentUI"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="clr-namespace:Gallery.Controls"
  xmlns:viewModel="clr-namespace:Gallery.ViewModels"
  Title="基本输入"
  d:DesignHeight="450"
  d:DesignWidth="800"
  x:DataType="viewModel:BasicInputViewModel"
  mc:Ignorable="d">

  <ui:ViewBase.Styles>
    <Style Selector="TextBox">
      <Setter Property="MinWidth" Value="128"/>
    </Style>

    <Style Selector="TextBlock.Title">
      <Setter Property="FontSize" Value="28"/>
      <Setter Property="Margin" Value="0 5 0 15"/>
      <Setter Property="FontWeight" Value="ExtraBold"/>
    </Style>

    <Style Selector="ui|CodeCard /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Padding" Value="15"/>
    </Style>
  </ui:ViewBase.Styles>

  <StackPanel Spacing="50">
    <ui:CodeCard Name="StandardButtonCard" Title="标准按钮">
      <Grid ColumnDefinitions="*, Auto">
        <StackPanel
          Grid.Column="0"
          Orientation="Vertical"
          Spacing="8">
          <fui:PushButton
            Width="{Binding PushButtonWidth}"
            Height="{Binding PushButtonHeight}"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            HorizontalContentAlignment="{Binding PushButtonContentAlignment}"
            Content="标准按钮"
            IsEnabled="{Binding !PushButtonIsDisable}"/>

          <fui:PushButton
            Width="{Binding PushButtonWidth}"
            Height="{Binding PushButtonHeight}"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            HorizontalContentAlignment="{Binding PushButtonContentAlignment}"
            Content="带有文本的透明标准按钮"
            IsEnabled="{Binding !PushButtonIsDisable}"
            Theme="{StaticResource TransparentPushButton}"/>

          <fui:PushButton
            Width="{Binding PushButtonWidth}"
            Height="{Binding PushButtonHeight}"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            HorizontalContentAlignment="{Binding PushButtonContentAlignment}"
            Content="带有图标文本的标准按钮"
            IconData="{StaticResource GitHub}"
            IsEnabled="{Binding !PushButtonIsDisable}"/>

          <fui:PushButton
            Width="{Binding PushButtonWidth}"
            Height="{Binding PushButtonHeight}"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            HorizontalContentAlignment="{Binding PushButtonContentAlignment}"
            Content="带有图标文本的透明标准按钮"
            IconData="{StaticResource GitHub}"
            IsEnabled="{Binding !PushButtonIsDisable}"
            Theme="{StaticResource TransparentPushButton}"/>

          <fui:PushButton
            Width="{Binding PushButtonWidth}"
            Height="{Binding PushButtonHeight}"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            HorizontalContentAlignment="{Binding PushButtonContentAlignment}"
            Classes="accent"
            Content="主题色标准按钮"
            IconData="{StaticResource Home}"
            IsEnabled="{Binding !PushButtonIsDisable}"/>
        </StackPanel>

        <ui:Card
          Grid.Column="1"
          Width="256"
          VerticalAlignment="Stretch">
          <StackPanel Orientation="Vertical">
            <TextBlock
              HorizontalAlignment="Left"
              FontWeight="Bold"
              Text="选项"/>

            <TextBlock HorizontalAlignment="Left" Text="宽度"/>
            <fui:ToolTipSlider
              Maximum="{Binding PushButtonMaximumWidth}"
              Minimum="{Binding PushButtonMinimumWidth}"
              Value="{Binding PushButtonWidth}"/>

            <TextBlock HorizontalAlignment="Left" Text="高度"/>
            <fui:ToolTipSlider
              Maximum="{Binding PushButtonMaximumHeight}"
              Minimum="{Binding PushButtonMinimumHeight}"
              Value="{Binding PushButtonHeight}"/>

            <TextBlock HorizontalAlignment="Left" Text="内容对齐方式"/>
            <fui:FAComboBox
              Margin="0,1"
              HorizontalAlignment="Stretch"
              ItemsSource="{Binding HorizontalAlignments}"
              SelectedItem="{Binding PushButtonContentAlignment}"/>

            <CheckBox Content="是禁用的" IsChecked="{Binding PushButtonIsDisable}"/>
          </StackPanel>
        </ui:Card>
      </Grid>
    </ui:CodeCard>

    <ui:CodeCard Name="ToolButtonCard" Title="工具按钮">
      <Grid ColumnDefinitions="*, Auto">
        <StackPanel
          Grid.Column="0"
          Orientation="Vertical"
          Spacing="8">
          <fui:ToolButton
            Width="{Binding ToolButtonWidth}"
            Height="{Binding ToolButtonHeight}"
            HorizontalContentAlignment="{Binding ToolButtonContentAlignment}"
            IconData="{StaticResource Setting}"
            IsEnabled="{Binding !ToolButtonIsDisable}"/>
          <fui:ToolButton
            Width="{Binding ToolButtonWidth}"
            Height="{Binding ToolButtonHeight}"
            HorizontalContentAlignment="{Binding ToolButtonContentAlignment}"
            Foreground="DeepSkyBlue"
            IconData="{StaticResource Save}"
            IsEnabled="{Binding !ToolButtonIsDisable}"
            Theme="{StaticResource TransparentToolButton}"/>

          <fui:ToolButton
            Width="{Binding ToolButtonWidth}"
            Height="{Binding ToolButtonHeight}"
            HorizontalContentAlignment="{Binding ToolButtonContentAlignment}"
            Classes="accent"
            IconData="{StaticResource Wifi}"
            IsEnabled="{Binding !ToolButtonIsDisable}"/>
        </StackPanel>
        <ui:Card
          Grid.Column="1"
          Width="256"
          VerticalAlignment="Stretch">
          <StackPanel Orientation="Vertical">
            <TextBlock FontWeight="Bold" Text="选项"/>

            <TextBlock HorizontalAlignment="Left" Text="宽度"/>
            <fui:ToolTipSlider
              Maximum="{Binding ToolButtonMaximumWidth}"
              Minimum="{Binding ToolButtonMinimumWidth}"
              Value="{Binding ToolButtonWidth}"/>

            <TextBlock HorizontalAlignment="Left" Text="高度"/>
            <fui:ToolTipSlider
              Maximum="{Binding ToolButtonMaximumHeight}"
              Minimum="{Binding ToolButtonMinimumHeight}"
              Value="{Binding ToolButtonHeight}"/>

            <TextBlock HorizontalAlignment="Left" Text="内容对齐方式"/>
            <fui:FAComboBox
              Margin="0,1"
              HorizontalAlignment="Stretch"
              ItemsSource="{Binding HorizontalAlignments}"
              SelectedItem="{Binding ToolButtonContentAlignment}"/>
            <CheckBox Content="是禁用的" IsChecked="{Binding ToolButtonIsDisable}"/>
          </StackPanel>
        </ui:Card>
      </Grid>
    </ui:CodeCard>

    <ui:CodeCard Title="填充按钮">
      <Grid ColumnDefinitions="*, Auto">
        <StackPanel Orientation="Vertical" Spacing="8">
          <fui:FilledPushButton
            Width="128"
            Content="Information"
            IconData="{StaticResource Robot}"
            IsEnabled="{Binding !FilledButtonIsDisabled}"/>
          <fui:FilledPushButton
            Width="128"
            Classes="success"
            Content="Success"
            IconData="{StaticResource Share}"
            IsEnabled="{Binding !FilledButtonIsDisabled}"/>
          <fui:FilledPushButton
            Width="128"
            Classes="attention"
            Content="Attention"
            IconData="{StaticResource Save}"
            IsEnabled="{Binding !FilledButtonIsDisabled}"/>
          <fui:FilledPushButton
            Width="128"
            Classes="warning"
            Content="Warning"
            IconData="{StaticResource SpeedHigh}"
            IsEnabled="{Binding !FilledButtonIsDisabled}"/>
          <fui:FilledPushButton
            Width="128"
            Classes="error"
            Content="Error"
            IconData="{StaticResource Info}"
            IsEnabled="{Binding !FilledButtonIsDisabled}"/>
        </StackPanel>
        <ui:Card Grid.Column="1" Width="256">
          <StackPanel Orientation="Vertical" Spacing="3">
            <TextBlock FontWeight="Bold" Text="选项"/>
            <CheckBox Content="是禁用的" IsChecked="{Binding FilledButtonIsDisabled}"/>
          </StackPanel>
        </ui:Card>
      </Grid>
    </ui:CodeCard>

    <ui:CodeCard Title="描边按钮">
      <Grid ColumnDefinitions="*, Auto">
        <StackPanel
          Grid.Column="0"
          VerticalAlignment="Top"
          Orientation="Horizontal"
          Spacing="5">
          <fui:OutlinePushButton
            Content="音乐"
            GroupName="{Binding OutlinePushButtonGroupName}"
            IconData="{StaticResource Music}"
            IsEnabled="{Binding !OutlinePushButtonIsDisabled}"/>
          <fui:OutlinePushButton
            Content="电影和电视"
            GroupName="{Binding OutlinePushButtonGroupName}"
            IconData="{StaticResource Video}"
            IsEnabled="{Binding !OutlinePushButtonIsDisabled}"/>
          <fui:OutlinePushButton
            Content="游戏"
            GroupName="{Binding OutlinePushButtonGroupName}"
            IconData="{StaticResource Game}"
            IsEnabled="{Binding !OutlinePushButtonIsDisabled}"/>
          <fui:OutlinePushButton
            Content="GitHub"
            GroupName="{Binding OutlinePushButtonGroupName}"
            IconData="{StaticResource GitHub}"
            IsEnabled="{Binding !OutlinePushButtonIsDisabled}"/>
          <fui:OutlinePushButton
            Content="关于我们"
            GroupName="{Binding OutlinePushButtonGroupName}"
            IsEnabled="{Binding !OutlinePushButtonIsDisabled}"/>
        </StackPanel>
        <ui:Card Grid.Column="1">
          <StackPanel Orientation="Vertical" Spacing="3">
            <TextBlock FontWeight="Bold" Text="选项"/>
            <CheckBox Content="可多选" IsChecked="{Binding OutlinePushButtonIsMC}"/>
            <CheckBox Content="是禁用的" IsChecked="{Binding OutlinePushButtonIsDisabled}"/>
          </StackPanel>
        </ui:Card>
      </Grid>
    </ui:CodeCard>

    <ui:CodeCard Title="描边工具按钮">
      <Grid ColumnDefinitions="*, Auto">
        <StackPanel
          Grid.Column="0"
          VerticalAlignment="Top"
          Orientation="Horizontal"
          Spacing="5">
          <fui:OutlineToolButton
            GroupName="{Binding OutlineToolButtonGroupName}"
            IconData="{StaticResource Add}"
            IsEnabled="{Binding !OutlineToolButtonIsDisabled}"/>
          <fui:OutlineToolButton
            GroupName="{Binding OutlineToolButtonGroupName}"
            IconData="{StaticResource Bluetooth}"
            IsEnabled="{Binding !OutlineToolButtonIsDisabled}"/>
          <fui:OutlineToolButton
            GroupName="{Binding OutlineToolButtonGroupName}"
            IconData="{StaticResource Brush}"
            IsEnabled="{Binding !OutlineToolButtonIsDisabled}"/>
        </StackPanel>
        <ui:Card Grid.Column="1">
          <StackPanel Orientation="Vertical" Spacing="3">
            <TextBlock FontWeight="Bold" Text="选项"/>
            <CheckBox Content="可多选" IsChecked="{Binding OutlineToolButtonIsMC}"/>
            <CheckBox Content="是禁用的" IsChecked="{Binding OutlineToolButtonIsDisabled}"/>
          </StackPanel>
        </ui:Card>
      </Grid>
    </ui:CodeCard>

    <ui:CodeCard Name="DropDownButtonCard" Title="带下拉菜单的按钮">
      <Grid ColumnDefinitions="*, Auto">
        <DropDownButton Width="128" IsEnabled="{Binding !DropDownButtonIsDisable}">
          <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
            <PathIcon Data="{StaticResource Mail}"/>
            <TextBlock Grid.Column="1" Text="邮件"/>
          </Grid>
          <DropDownButton.Flyout>
            <fui:FluentMenuFlyout>
              <MenuItem Header="发送">
                <MenuItem.Icon>
                  <PathIcon Data="{StaticResource Send}"/>
                </MenuItem.Icon>
                <MenuItem.Items>
                  <MenuItem Header="发送到本地"/>
                  <MenuItem Header="发送到网络"/>
                </MenuItem.Items>
              </MenuItem>
              <MenuItem Header="保存">
                <MenuItem.Icon>
                  <PathIcon Data="{StaticResource Save}"/>
                </MenuItem.Icon>
              </MenuItem>
              <Separator HorizontalAlignment="Stretch"/>
              <MenuItem Header="撤销"/>
              <MenuItem Header="重新发送"/>
              <MenuItem Header="保存到本地"/>
            </fui:FluentMenuFlyout>
          </DropDownButton.Flyout>
        </DropDownButton>

        <CheckBox
          Grid.Column="1"
          Content="是禁用的"
          IsChecked="{Binding DropDownButtonIsDisable}"/>
      </Grid>
    </ui:CodeCard>

    <ui:CodeCard Name="TransparentDropDownButtonCard" Title="带下拉菜单的透明按钮">
      <Grid ColumnDefinitions="*, Auto">
        <DropDownButton
          Name="Test"
          Width="128"
          IsEnabled="{Binding !TransparentDropDownButtonIsDisable}"
          Theme="{StaticResource TransparentDropDownButton}">
          <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
            <PathIcon Data="{StaticResource Mail}"/>
            <TextBlock Grid.Column="1" Text="邮件"/>
          </Grid>
          <DropDownButton.Flyout>
            <fui:FluentMenuFlyout>
              <MenuItem Header="发送">
                <MenuItem.Icon>
                  <PathIcon Data="{StaticResource Send}"/>
                </MenuItem.Icon>
                <MenuItem.Items>
                  <MenuItem Header="发送到本地"/>
                  <MenuItem Header="发送到网络"/>
                </MenuItem.Items>
              </MenuItem>
              <MenuItem Header="保存">
                <MenuItem.Icon>
                  <PathIcon Data="{StaticResource Save}"/>
                </MenuItem.Icon>
              </MenuItem>
              <Separator HorizontalAlignment="Stretch"/>
              <MenuItem Header="撤销"/>
              <MenuItem Header="重新发送"/>
              <MenuItem Header="保存到本地"/>
            </fui:FluentMenuFlyout>
          </DropDownButton.Flyout>
        </DropDownButton>

        <CheckBox
          Grid.Column="1"
          Content="是禁用的"
          IsChecked="{Binding TransparentDropDownButtonIsDisable}"/>
      </Grid>
    </ui:CodeCard>

    <!-- <ui:CodeCard Title="带有文本的透明标准按钮"> -->
    <!-- <fui:PushButton Content="带有文本的透明标准按钮" Theme="{StaticResource TransparentPushButton}"/> -->
    <!-- </ui:CodeCard> -->

    <!-- <ui:CodeCard Title="带有图标文本的标准按钮"> -->
    <!-- <fui:PushButton Content="带有图标文本的标准按钮" IconData="{StaticResource GitHub}"/> -->
    <!-- </ui:CodeCard> -->

    <!-- <ui:CodeCard Title="带有图标文本的透明标准按钮"> -->
    <!--  <fui:PushButton  -->
    <!--  Content="带有图标文本的透明标准按钮"  -->
    <!--  IconData="{StaticResource GitHub}"  -->
    <!--  Theme="{StaticResource TransparentPushButton}"/>  -->
    <!-- </ui:CodeCard> -->

    <!-- <ui:CodeCard Title="主题色标准按钮"> -->
    <!--  <fui:PushButton  -->
    <!--  Classes="accent"  -->
    <!--  Content="主题色标准按钮"  -->
    <!--  IconData="{StaticResource Home}"/>  -->
    <!-- </ui:CodeCard> -->

    <!-- <ui:CodeCard Title="透明工具按钮"> -->
    <!--  <fui:ToolButton  -->
    <!--  Foreground="DeepSkyBlue"  -->
    <!--  IconData="{StaticResource Save}"  -->
    <!--  Theme="{StaticResource TransparentToolButton}"/>  -->
    <!-- </ui:CodeCard> -->
    <!-- <ui:CodeCard Title="主题色工具按钮"> -->
    <!-- <fui:ToolButton Classes="accent" IconData="{StaticResource Wifi}"/> -->
    <!-- </ui:CodeCard> -->

    <!--  //////////  -->

    <ui:CodeCard Name="ToggleButtonCard" Title="状态开关按钮">
      <Grid ColumnDefinitions="*, Auto">
        <StackPanel Orientation="Vertical" Spacing="8">
          <ToggleButton Content="开关按钮" IsEnabled="{Binding !StatusSwitchButtonIsDisable}"/>
          <ToggleButton
            Content="透明状态开关按钮"
            IsEnabled="{Binding !StatusSwitchButtonIsDisable}"
            Theme="{StaticResource TransparentToggleButton}"/>
          <ToggleSplitButton Content="分割状态开关按钮" IsEnabled="{Binding !StatusSwitchButtonIsDisable}">
            <ToggleSplitButton.Flyout>
              <fui:FluentMenuFlyout>
                <MenuItem Header="复制" InputGesture="Ctrl+C"/>
                <MenuItem Header="剪切" InputGesture="Ctrl+X"/>
                <MenuItem Header="粘贴" InputGesture="Ctrl+V"/>
                <MenuItem Header="撤销" InputGesture="Ctrl+Z"/>
              </fui:FluentMenuFlyout>
            </ToggleSplitButton.Flyout>
          </ToggleSplitButton>
        </StackPanel>
        <CheckBox
          Grid.Column="1"
          Content="是禁用的"
          IsChecked="{Binding StatusSwitchButtonIsDisable}"/>
      </Grid>
    </ui:CodeCard>

    <!-- <ui:CodeCard Title="状态开关按钮"> -->
    <!--   <ToggleButton Content="开关按钮"/> -->
    <!-- </ui:CodeCard> -->
    <!--    -->
    <!-- <ui:CodeCard Title="透明状态开关按钮"> -->
    <!--   <ToggleButton Content="透明状态开关按钮" Theme="{StaticResource TransparentToggleButton}"/> -->
    <!-- </ui:CodeCard> -->
    <!--    -->
    <!-- <ui:CodeCard Title="分割状态开关按钮"> -->
    <!--   <ToggleSplitButton Content="分割按钮"> -->
    <!--     <ToggleSplitButton.Flyout> -->
    <!--       <MenuFlyout> -->
    <!--         <MenuItem Header="复制" InputGesture="Ctrl+C"/> -->
    <!--         <MenuItem Header="剪切" InputGesture="Ctrl+X"/> -->
    <!--         <MenuItem Header="粘贴" InputGesture="Ctrl+V"/> -->
    <!--         <MenuItem Header="撤销" InputGesture="Ctrl+Z"/> -->
    <!--       </MenuFlyout> -->
    <!--     </ToggleSplitButton.Flyout> -->
    <!--   </ToggleSplitButton> -->
    <!-- </ui:CodeCard> -->

    <ui:CodeCard Name="SplitButtonCard" Title="拆分按钮">
      <Grid ColumnDefinitions="*, Auto">
        <SplitButton Content="复制" IsEnabled="{Binding !SplitButtonIsDisable}">
          <SplitButton.Flyout>
            <fui:FluentMenuFlyout>
              <MenuItem Header="复制" InputGesture="Ctrl+C"/>
              <MenuItem Header="剪切" InputGesture="Ctrl+X"/>
              <MenuItem Header="粘贴" InputGesture="Ctrl+V"/>
              <MenuItem Header="撤销" InputGesture="Ctrl+Z"/>
            </fui:FluentMenuFlyout>
          </SplitButton.Flyout>
        </SplitButton>
        <CheckBox
          Grid.Column="1"
          Content="是禁用的"
          IsChecked="{Binding SplitButtonIsDisable}"/>
      </Grid>
    </ui:CodeCard>

    <ui:CodeCard Name="RadioButtonCard" Title="单选按钮">
      <Grid
        ColumnDefinitions="*, Auto"
        ColumnSpacing="3"
        RowDefinitions="Auto, Auto, Auto, Auto">
        <RadioButton
          Grid.Row="0"
          Grid.ColumnSpan="2"
          Content="扬声器"
          IsEnabled="{Binding !RadioButtonIsDisabled}"/>
        <RadioButton
          Grid.Row="1"
          Grid.ColumnSpan="2"
          Content="耳机"
          IsEnabled="{Binding !RadioButtonIsDisabled}"/>
        <RadioButton
          Grid.Row="2"
          Grid.ColumnSpan="2"
          Content="控制器"
          IsEnabled="{Binding !RadioButtonIsDisabled}"/>
        <RadioButton
          Grid.Row="3"
          Grid.ColumnSpan="2"
          Content="蓝牙"
          IsEnabled="{Binding !RadioButtonIsDisabled}"/>

        <CheckBox
          Grid.Row="0"
          Grid.Column="1"
          Content="是禁用的"
          IsChecked="{Binding RadioButtonIsDisabled}"/>
      </Grid>
    </ui:CodeCard>


    <ui:CodeCard Title="带子标题的单选按钮">
      <Grid
        ColumnDefinitions="*, Auto"
        ColumnSpacing="3"
        RowDefinitions="Auto, Auto, Auto, Auto">
        <fui:SubTitleRadioButton
          Grid.Row="0"
          Grid.ColumnSpan="2"
          Content="扬声器"
          IsEnabled="{Binding !SubTitleRadioButtonIsDisabled}"
          SubTitle="Realted(R) Audio"/>
        <fui:SubTitleRadioButton
          Grid.Row="1"
          Grid.ColumnSpan="2"
          Content="耳机"
          IsEnabled="{Binding !SubTitleRadioButtonIsDisabled}"
          SubTitle="AirPods Pro 2"/>
        <fui:SubTitleRadioButton
          Grid.Row="2"
          Grid.ColumnSpan="2"
          Content="控制器"
          IsEnabled="{Binding !SubTitleRadioButtonIsDisabled}"
          SubTitle="Xbox Wireless Controller"/>
        <fui:SubTitleRadioButton
          Grid.Row="3"
          Grid.ColumnSpan="2"
          Content="蓝牙"
          IsEnabled="{Binding !SubTitleRadioButtonIsDisabled}"
          SubTitle="ProjectLuo M2"/>

        <CheckBox
          Grid.Row="0"
          Grid.Column="1"
          Content="是禁用的"
          IsChecked="{Binding SubTitleRadioButtonIsDisabled}"/>
      </Grid>
    </ui:CodeCard>

    <ui:CodeCard Name="HyperlinkButtonCard" Title="超链接按钮">
      <Grid ColumnDefinitions="*, Auto">

        <HyperlinkButton
          Grid.Column="0"
          Content="我是超链接按钮"
          IsEnabled="{Binding !HyperlinkButtonIsDisable}"
          NavigateUri="https://mikuas.top"/>
        <CheckBox
          Grid.Column="1"
          Content="是禁用的"
          IsChecked="{Binding HyperlinkButtonIsDisable}"/>
      </Grid>
    </ui:CodeCard>

    <ui:CodeCard Name="ToggleSwitchButtonCard" Title="开关按钮">
      <Grid ColumnDefinitions="*, Auto">
        <ToggleSwitch
          Grid.Column="0"
          Content="开启蓝牙"
          IsEnabled="{Binding !ToggleSwitchButtonIsDisable}"/>
        <CheckBox
          Grid.Column="1"
          Content="是禁用的"
          IsChecked="{Binding ToggleSwitchButtonIsDisable}"/>
      </Grid>
    </ui:CodeCard>

    <!--  //////////  -->
    <ui:CodeCard Name="CheckBoxCard" Title="复选框">
      <Grid ColumnDefinitions="*, Auto">
        <CheckBox
          Grid.Column="0"
          HorizontalAlignment="Left"
          Content="复选框"
          IsEnabled="{Binding !CheckBoxIsDisable}"
          IsThreeState="{Binding CheckBoxIsThreeState}"/>

        <ui:Card
          Grid.Column="1"
          Width="256"
          VerticalAlignment="Stretch">
          <StackPanel Orientation="Vertical">
            <TextBlock FontWeight="Bold" Text="选项"/>

            <CheckBox Content="启用三态" IsChecked="{Binding CheckBoxIsThreeState}"/>
            <CheckBox Content="是禁用的" IsChecked="{Binding CheckBoxIsDisable}"/>
          </StackPanel>
        </ui:Card>
      </Grid>
    </ui:CodeCard>

    <ui:CodeCard Name="ComboBoxCard" Title="下拉框">
      <fui:FluentComboBox
        Width="256"
        ItemsSource="{Binding Items}"
        SelectedIndex="0"/>
    </ui:CodeCard>

    <ui:CodeCard Title="多选下拉框">
      <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
        <fui:MultiSelectionComboBox
          VerticalAlignment="Top"
          ItemsSource="{Binding MultiSelectionItems}"
          SelectedItems="{Binding MultiSelectionSelectedItems}"/>
        <ui:Card Grid.Column="1" Width="256">
          <StackPanel Orientation="Vertical" Spacing="6">
            <TextBlock FontWeight="Bold" Text="选项"/>
            <Button
              Command="{Binding SelectOddOrEventNumberItemsCommand}"
              CommandParameter="1"
              Content="选中奇数项目"/>
            <Button
              Command="{Binding SelectOddOrEventNumberItemsCommand}"
              CommandParameter="0"
              Content="选中偶数项目"/>
            <Button Command="{Binding ClearMultiSelectionSelectedItemCommand}" Content="清空选定的项目"/>
          </StackPanel>
        </ui:Card>
      </Grid>
    </ui:CodeCard>

    <ui:CodeCard Name="SliderCard" Title="滑动条">
      <Grid ColumnDefinitions="*, Auto">
        <Slider
          Grid.Column="0"
          Width="328"
          HorizontalAlignment="Left"
          Maximum="100"
          Minimum="0"
          Value="{Binding SliderCurrentValue}"/>
        <TextBlock
          Grid.Column="1"
          HorizontalAlignment="Right"
          VerticalAlignment="Center"
          Text="{Binding SliderCurrentValueFormat}"/>
      </Grid>
    </ui:CodeCard>

    <ui:CodeCard Name="ToolTipSliderCard" Title="带工具提示的滑动条">
      <fui:ToolTipSlider
        Width="328"
        HorizontalAlignment="Left"
        Maximum="100"
        Minimum="0"/>
    </ui:CodeCard>

    <ui:CodeCard Name="RangeSliderCard" Title="范围滑动条">
      <fui:RangeSlider
        Width="328"
        HorizontalAlignment="Left"
        Maximum="100"
        Minimum="0"/>
    </ui:CodeCard>

    <ui:CodeCard Name="ColorSliderCard" Title="颜色滑动条">
      <ColorSlider
        Width="328"
        HorizontalAlignment="Left"
        Color="DeepSkyBlue"/>
    </ui:CodeCard>

    <!-- <ui:CodeCard Title="可编辑的下拉框"> -->
    <!--  <fui:FAComboBox  -->
    <!--  IsEditable="True"  -->
    <!--  Items="{Binding Items}"  -->
    <!--  SelectedIndex="0"/>  -->
    <!-- </ui:CodeCard> -->


  </StackPanel>
</ui:ViewBase>
