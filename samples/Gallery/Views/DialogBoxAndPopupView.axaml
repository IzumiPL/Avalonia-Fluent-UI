<ui:ViewBase
  x:Class="Gallery.Views.DialogBoxAndPopupView"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:fui="clr-namespace:AvaloniaFluentUI.UI.Controls;assembly=AvaloniaFluentUI"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="clr-namespace:Gallery.Controls"
  xmlns:viewModel="clr-namespace:Gallery.ViewModels"
  Title="对话框和弹出窗口"
  d:DesignHeight="450"
  d:DesignWidth="800"
  x:DataType="viewModel:DialogBoxAndPopupViewModel"
  mc:Ignorable="d">

  <ui:ViewBase.Styles>
    <Style Selector="Flyout FlyoutPresenter">
      <Setter Property="Margin" Value="0"/>
      <Setter Property="Padding" Value="0"/>
    </Style>
  </ui:ViewBase.Styles>

  <StackPanel Spacing="50">
    <fui:ContentDialog
      Name="ContentDialog"
      Title="这是一个带遮罩的对话框"
      CloseButtonText="关闭"
      Content="只要你保持乐观的心态, 你就会发现这个世界上有数不尽的开心事!"
      DefaultButton="Primary"
      IsPrimaryButtonEnabled="True"
      IsVisible="False"
      PrimaryButtonText="确认"/>
    <ui:CodeCard Name="ContentDialogCard" Title="带遮罩的对话框">
      <Button Click="OnShowContentDialog" Content="显示对话框"/>
    </ui:CodeCard>

    <fui:ContentDialog
      Name="CustomDialog"
      Title="打开URL"
      CloseButtonText="关闭"
      DefaultButton="Primary"
      IsPrimaryButtonEnabled="True"
      IsVisible="False"
      PrimaryButtonText="打开">
      <TextBox
        HorizontalAlignment="Stretch"
        VerticalAlignment="Center"
        Watermark="输入文件, 流或者播放列表的 URL"/>
    </fui:ContentDialog>
    <ui:CodeCard Title="自定义对话框">
      <Button Click="OnShowCustomDialog" Content="显示对话框"/>
    </ui:CodeCard>

    <ui:CodeCard Name="TaskDialogCard" Title="任务对话框">
      <Button Click="OnShowTaskDialog" Content="显示任务对话框"/>
    </ui:CodeCard>

    <ui:CodeCard Name="FlyoutCard" Title="Fluent浮出控件">
      <Grid ColumnDefinitions="*, Auto, Auto">

        <Button
          Grid.Column="0"
          Width="128"
          Content="显示弹出视图">
          <Button.Flyout>
            <fui:FluentFlyout IsOpen="{Binding FluentFlyoutIsOpen, Mode=TwoWay}" Placement="{Binding FlyoutPlacement}">
              <Border Margin="0" Padding="0">
                <Grid
                  Margin="0"
                  ColumnDefinitions="*, *"
                  RowDefinitions="Auto, Auto, Auto, Auto">
                  <TextBlock
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Margin="10,10,10,1"
                    HorizontalAlignment="Left"
                    FontSize="24"
                    Text="无名"/>
                  <TextBlock
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="10,1,10,12"
                    HorizontalAlignment="Left"
                    Text="左眼用来忘记你，右眼用来记住你。"/>

                  <Separator
                    Grid.Row="2"
                    Grid.ColumnSpan="2"
                    HorizontalAlignment="Stretch"/>

                  <Button
                    Grid.Row="3"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    BorderThickness="0"
                    Command="{Binding CloseFlyoutCommand}"
                    Theme="{StaticResource TransparentButton}">
                    <fui:SymbolIcon FontSize="18" Symbol="Accept"/>

                  </Button>
                  <Button
                    Grid.Row="3"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    BorderThickness="0"
                    Command="{Binding CloseFlyoutCommand}"
                    Theme="{StaticResource TransparentButton}">
                    <fui:SymbolIcon FontSize="18" Symbol="Clear"/>
                  </Button>
                  <!--  <fui:ToolButton  -->
                  <!--  Grid.Row="3"  -->
                  <!--  Grid.Column="0"  -->
                  <!--  HorizontalAlignment="Stretch"  -->
                  <!--  Command="{Binding CloseFlyoutCommand}"  -->
                  <!--  IconData="{StaticResource Accept}"  -->
                  <!--  Theme="{StaticResource TransparentToolButton}"/>  -->
                  <!--  <fui:ToolButton  -->
                  <!--  Grid.Row="3"  -->
                  <!--  Grid.Column="1"  -->
                  <!--  HorizontalAlignment="Stretch"  -->
                  <!--  Command="{Binding CloseFlyoutCommand}"  -->
                  <!--  IconData="{StaticResource Close}"  -->
                  <!--  Theme="{StaticResource TransparentToolButton}"/>  -->
                </Grid>
              </Border>
            </fui:FluentFlyout>
          </Button.Flyout>
        </Button>

        <TextBlock
          Grid.Column="1"
          HorizontalAlignment="Right"
          VerticalAlignment="Center"
          Text="弹出位置: "/>
        <fui:FluentComboBox
          Grid.Column="2"
          Width="256"
          Margin="8,0,12,0"
          HorizontalAlignment="Right"
          VerticalAlignment="Center"
          ItemsSource="{Binding FlyoutPlacements}"
          SelectedItem="{Binding FlyoutPlacement}"/>
      </Grid>
    </ui:CodeCard>

    <ui:CodeCard Title="带图片和按钮的浮出控件">
      <Button Content="显示浮出控件">
        <Button.Flyout>
          <fui:FluentFlyout IsOpen="{Binding FluentFlyoutIsOpen, Mode=TwoWay}" Placement="Right">
            <Grid
              Width="512"
              Height="388"
              RowDefinitions="*, Auto, Auto, Auto">
              <Image
                Grid.Row="0"
                Source="avares://Gallery/Assets/Images/mc.jpg"
                Stretch="UniformToFill"/>
              <TextBlock
                Grid.Row="1"
                Margin="10,10,0,2"
                HorizontalAlignment="Left"
                FontFamily="Bold"
                FontSize="20"
                Text="Minecraft"/>
              <SelectableTextBlock
                Grid.Row="2"
                Margin="10,0,10,2"
                FontSize="12"
                Text="Forge(全称 Minecraft Forge)是一个为《我的世界》Java版设计的开源模组加载器(Mod Loader), 它为开发者提供了一套标准的开发接口, 让各种修改游戏功能的模组(Mod)能够互相兼容并在同一个游戏客户端中运行。"
                TextWrapping="WrapWithOverflow"/>
              <Button
                Grid.Row="3"
                Width="128"
                Margin="0,0,10,10"
                HorizontalAlignment="Right"
                Command="{Binding CloseFlyoutCommand}"
                Content="Action"/>
            </Grid>
          </fui:FluentFlyout>
        </Button.Flyout>
      </Button>
    </ui:CodeCard>

    <fui:TeachingTip
      Title="提示"
      ActionButtonCommand="{Binding CloseTeachingTipCommand}"
      ActionButtonContent="确认"
      IsLightDismissEnabled="True"
      IsOpen="{Binding TeachingTipIsOpen}"
      IsVisible="False"
      PreferredPlacement="Top"
      Subtitle="最短的捷径就是绕远路, 绕远路才是我的最短捷径."
      Target="{Binding ElementName=TeachingTipButton}"/>
    <ui:CodeCard Name="TeachingTipCard" Title="气泡弹窗">
      <Button
        Name="TeachingTipButton"
        Command="{Binding ShowTeachingTipCommand}"
        Content="显示气泡弹窗"/>
    </ui:CodeCard>

    <ui:CodeCard Title="颜色选择器">
      <ColorPicker HorizontalAlignment="Left" VerticalAlignment="Center"/>
    </ui:CodeCard>

  </StackPanel>
</ui:ViewBase>
