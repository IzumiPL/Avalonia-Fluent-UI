<ResourceDictionary
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:sys="clr-namespace:System;assembly=netstandard"
  x:CompileBindings="True">
  <Design.PreviewWith>
    <Border Padding="20">
      <StackPanel Spacing="20">
        <ButtonSpinner/>
        <ButtonSpinner
          AllowSpin="False"
          ButtonSpinnerLocation="Right"
          Content="Right disabled inline spinner">
          <DataValidationErrors.Error>
            <sys:Exception/>
          </DataValidationErrors.Error>
        </ButtonSpinner>
        <ButtonSpinner ButtonSpinnerLocation="Left" Content="Left spinner"/>
        <ButtonSpinner Content="Hide spinner" ShowButtonSpinner="False"/>
      </StackPanel>
    </Border>
  </Design.PreviewWith>

  <ControlTheme
    x:Key="ButtonSpinnerButton"
    BasedOn="{StaticResource TransparentRepeatButton}"
    TargetType="RepeatButton">
    <Setter Property="MinWidth" Value="32"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="VerticalAlignment" Value="Stretch"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
    <Setter Property="BorderThickness" Value="{DynamicResource NumberBoxSpinButtonBorderThickness}"/>
    <Setter Property="FontFamily" Value="{DynamicResource SymbolThemeFontFamily}"/>
  </ControlTheme>

  <ControlTheme x:Key="{x:Type ButtonSpinner}" TargetType="ButtonSpinner">
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
    <Setter Property="Padding" Value="10, 0"/>
    <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefault}"/>
    <Setter Property="BorderThickness" Value="{DynamicResource TextControlBorderThemeThickness}"/>
    <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}"/>
    <Setter Property="MinHeight" Value="{DynamicResource TextControlThemeMinHeight}"/>
    <Setter Property="MinWidth" Value="{DynamicResource TextControlThemeMinWidth}"/>
    <Setter Property="FontSize" Value="{DynamicResource ControlContentThemeFontSize}"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Focusable" Value="True"/>
    <Setter Property="Template">
      <ControlTemplate>
        <DataValidationErrors>
          <Border
            Name="LayoutRoot"
            MinHeight="{TemplateBinding MinHeight}"
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="{TemplateBinding CornerRadius}">
            <Grid ColumnDefinitions="Auto,*,Auto">
              <ContentPresenter
                Name="PART_ContentPresenter"
                Grid.Column="1"
                Padding="{TemplateBinding Padding}"
                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}"/>

              <StackPanel
                Name="PART_SpinnerPanel"
                Grid.Column="0"
                IsVisible="{TemplateBinding ShowButtonSpinner}"
                Orientation="Horizontal">
                <RepeatButton
                  Name="PART_IncreaseButton"
                  Margin="4"
                  VerticalContentAlignment="Center"
                  Content="&#xE70E;"
                  FontSize="18"
                  Foreground="{TemplateBinding Foreground}"
                  Theme="{StaticResource ButtonSpinnerButton}"/>

                <RepeatButton
                  Name="PART_DecreaseButton"
                  Margin="0,4,4,4"
                  VerticalContentAlignment="Center"
                  Content="&#xE70D;"
                  FontSize="18"
                  Foreground="{TemplateBinding Foreground}"
                  Theme="{StaticResource ButtonSpinnerButton}"/>
              </StackPanel>
            </Grid>
          </Border>
        </DataValidationErrors>
      </ControlTemplate>
    </Setter>
    <Style Selector="^:right /template/ StackPanel#PART_SpinnerPanel">
      <Setter Property="Grid.Column" Value="2"/>
    </Style>
    <Style Selector="^:error">
      <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
    </Style>
  </ControlTheme>
</ResourceDictionary>
