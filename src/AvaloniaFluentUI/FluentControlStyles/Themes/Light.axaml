  <SolidColorBrush x:Key="SystemColorButtonFaceColorBrush" Color="#FF00FF"/>
  <SolidColorBrush x:Key="SystemColorButtonTextColorBrush" Color="#FF00FF"/>
  <SolidColorBrush x:Key="SystemColorHighlightColorBrush" Color="#FF00FF"/>
  <SolidColorBrush x:Key="SystemColorHighlightTextColorBrush" Color="#FF00FF"/>
  <SolidColorBrush x:Key="SystemColorHotlightColorBrush" Color="#FF00FF"/>
  <SolidColorBrush x:Key="SystemColorGrayTextColorBrush" Color="#FF00FF"/>

  <LinearGradientBrush x:Key="ControlElevationBorderBrush" TransformOrigin="50%,50%" StartPoint="0,0" EndPoint="0,3">
    <LinearGradientBrush.Transform>
      <ScaleTransform ScaleY="-1"/>
    </LinearGradientBrush.Transform>
    <LinearGradientBrush.GradientStops>
      <GradientStop Offset="0.33" Color="{StaticResource ControlStrokeColorSecondary}"/>
      <GradientStop Offset="1" Color="{StaticResource ControlStrokeColorDefault}"/>
    </LinearGradientBrush.GradientStops>
  </LinearGradientBrush>

  <!--  This one does not have a transform applied, so this one should be ok  -->

  <LinearGradientBrush x:Key="CircleElevationBorderBrush" StartPoint="0,0" EndPoint="0,1">
    <LinearGradientBrush.GradientStops>
      <GradientStop Offset="0.50" Color="{StaticResource ControlStrokeColorDefault}"/>
      <GradientStop Offset="0.70" Color="{StaticResource ControlStrokeColorSecondary}"/>
    </LinearGradientBrush.GradientStops>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="AccentControlElevationBorderBrush" TransformOrigin="50%,50%" StartPoint="0,0" EndPoint="0,3">
    <LinearGradientBrush.Transform>
      <ScaleTransform ScaleY="-1"/>
    </LinearGradientBrush.Transform>
    <LinearGradientBrush.GradientStops>
      <GradientStop Offset="0.33" Color="{StaticResource ControlStrokeColorOnAccentSecondary}"/>
      <GradientStop Offset="1.0" Color="{StaticResource ControlStrokeColorOnAccentDefault}"/>
    </LinearGradientBrush.GradientStops>
  </LinearGradientBrush>
  <SolidColorBrush x:Key="SystemControlTransparentBrush" Color="Transparent"/>
  <SolidColorBrush
    x:Key="SystemControlHighlightListAccentVeryHighBrush"
    Opacity="0.9"
    Color="{DynamicResource SystemAccentColor}"/>
  <SolidColorBrush
    x:Key="SystemControlHighlightListAccentMediumLowBrush"
    Opacity="0.75"
    Color="{DynamicResource SystemAccentColor}"/>
  <x:Boolean x:Key="UseSystemFocusVisuals">True</x:Boolean>

  <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource SolidBackgroundFillColorBase}"/>
  <StaticResource x:Key="DefaultTextForegroundThemeBrush" ResourceKey="TextFillColorPrimaryBrush"/>
  <StaticResource x:Key="SystemControlFocusVisualPrimaryBrush" ResourceKey="FocusStrokeColorOuterBrush"/>
  <StaticResource x:Key="SystemControlFocusVisualSecondaryBrush" ResourceKey="FocusStrokeColorInnerBrush"/>
  <SolidColorBrush x:Key="AcrylicBackgroundFillColorDefaultBrush" Color="#F9F9F9"/>
  <SolidColorBrush x:Key="AcrylicInAppFillColorDefaultBrush" Color="#F9F9F9"/>
  <SolidColorBrush x:Key="AcrylicBackgroundFillColorDefaultInverseBrush" Color="#2C2C2C"/>
  <SolidColorBrush x:Key="AcrylicInAppFillColorDefaultInverseBrush" Color="#2C2C2C"/>
  <SolidColorBrush x:Key="AcrylicBackgroundFillColorBaseBrush" Color="#EEEEEE"/>
  <SolidColorBrush x:Key="AcrylicInAppFillColorBaseBrush" Color="#EEEEEE"/>
  <SolidColorBrush x:Key="AccentAcrylicBackgroundFillColorDefaultBrush" Color="{DynamicResource SystemAccentColorLight3}"/>
  <SolidColorBrush x:Key="AccentAcrylicInAppFillColorDefaultBrush" Color="{DynamicResource SystemAccentColorLight3}"/>
  <SolidColorBrush x:Key="AccentAcrylicBackgroundFillColorBaseBrush" Color="{DynamicResource SystemAccentColorLight3}"/>
  <SolidColorBrush x:Key="AccentAcrylicInAppFillColorBaseBrush" Color="{DynamicResource SystemAccentColorLight3}"/>
  <SolidColorBrush x:Key="InformationDefaultBrush" Color="{StaticResource Information}"/>
  <SolidColorBrush x:Key="SuccessDefaultBrush" Color="{StaticResource Success}"/>
  <SolidColorBrush x:Key="AttentionDefaultBrush" Color="{StaticResource Attention}"/>
  <SolidColorBrush x:Key="WarningDefaultBrush" Color="{StaticResource Warning}"/>
  <SolidColorBrush x:Key="ErrorDefaultBrush" Color="{StaticResource Error}"/>
  <SolidColorBrush x:Key="FilledBackgroundPointerOver" Color="{StaticResource FilledPointerOver}"/>
  <SolidColorBrush x:Key="FilledBackgroundPressed" Color="{StaticResource FilledPressed}"/>
  <SolidColorBrush x:Key="FilledBorderBackgroundPointerOver" Color="{StaticResource FilledBorderPointerOver}"/>
  <SolidColorBrush x:Key="ColorControlLightSelectorBrush" Color="#FFFFFFFF"/>
  <SolidColorBrush x:Key="ColorControlDarkSelectorBrush" Color="#E4000000"/>
  <SolidColorBrush x:Key="ColorViewContentBackgroundBrush" Color="Transparent"/>
  <SolidColorBrush x:Key="ColorViewContentBorderBrush" Color="Transparent"/>
  <SolidColorBrush x:Key="ColorViewTabBorderBrush" Color="Transparent"/>
  <SolidColorBrush x:Key="TeachingTipTopHighlightBrush" Color="#99FFFFFF"/>

  <SolidColorBrush x:Key="SystemControlForegroundTransparentBrush" Color="Transparent"/>
  <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="{DynamicResource SystemAccentColor}"/>
  <SolidColorBrush
    x:Key="SystemControlHighlightListAccentLowBrush"
    Opacity="0.6"
    Color="{DynamicResource SystemAccentColor}"/>
  <SolidColorBrush x:Key="SystemControlDescriptionTextForegroundBrush" Color="{StaticResource TextFillColorSecondary}"/>
</ResourceDictionary>
