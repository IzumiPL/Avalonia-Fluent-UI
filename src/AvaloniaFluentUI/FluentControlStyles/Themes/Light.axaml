  <Color x:Key="Success">#0F7B0F</Color>
  <Color x:Key="Attention">#009FAA</Color>
  <Color x:Key="Warning">#9D9D00</Color>
  <Color x:Key="Error">#D83F40</Color>
  <Color x:Key="FilledPointerOver">#C9CACB</Color>
  <Color x:Key="FilledPressed">#979798</Color>
  <Color x:Key="FilledBorderPointerOver">#85898B</Color>

